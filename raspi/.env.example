# GazozHMI Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# cp .env.example .env

# ── Arduino Nano Ayarları ──────────────────────────────────────────────────────
# Gerçek donanım portu (RPi'de genellikle /dev/ttyUSB0 veya /dev/ttyACM0)
ARDUINO_PORT=/dev/ttyUSB0
ARDUINO_BAUDRATE=9600

# Simülasyon modunu kapatmak için 'false' yapın
# true  → Arduino gerektirmez, tüm I/O simüle edilir
# false → Gerçek serialport bağlantısı açılır
ARDUINO_SIMULATION=true

# ── Veritabanı ─────────────────────────────────────────────────────────────────
# SQLite dosya yolu (varsayılan: ./gazoz.db)
DB_PATH=./gazoz.db

# ── Sunucu ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── Gemini API (opsiyonel) ─────────────────────────────────────────────────────
GEMINI_API_KEY=
